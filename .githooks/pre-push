#!/usr/bin/env bash
# Auto-bumps and pushes a new "vMAJOR.MINOR.PATCH" tag whenever the local
# "main" branch is pushed. The new tag push triggers release.yml, which
# builds and publishes the KiCad plugin release.
#
# Enable with: git config core.hooksPath .githooks

set -euo pipefail

# Avoid recursing when we push the tag ourselves below.
if [[ "${SKIP_AUTO_TAG:-}" == "1" ]]; then
  exit 0
fi

remote="$1"

pushing_main=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  if [[ "${remote_ref}" == "refs/heads/main" ]]; then
    pushing_main=1
  fi
done

if [[ "${pushing_main}" -ne 1 ]]; then
  exit 0
fi

git fetch --tags --force "${remote}" >/dev/null 2>&1 || true

# release.yml commits an updated packages.json ledger back to main after
# every release, so local main can easily be behind origin/main by the time
# the next push happens. Rebase onto the latest remote main first so our
# own commit below (and the push at the end) fast-forward cleanly instead
# of being rejected as a non-fast-forward/branch split.
if git rev-parse -q --verify "${remote}/main" >/dev/null 2>&1; then
  if ! git merge-base --is-ancestor "${remote}/main" HEAD; then
    echo "pre-push: local main is behind ${remote}/main; rebasing onto it..."
    if ! git rebase "${remote}/main"; then
      echo "pre-push: automatic rebase onto ${remote}/main failed (conflicts)." >&2
      echo "pre-push: resolve manually (see 'git status'), then re-run git push." >&2
      exit 1
    fi
  fi
fi

latest_tag="$(git tag --list 'v*.*.*' | sort -V | tail -n1)"

if [[ -z "${latest_tag}" ]]; then
  new_tag="v0.0.1"
else
  version="${latest_tag#v}"
  major="${version%%.*}"
  rest="${version#*.}"
  minor="${rest%%.*}"
  patch="${rest#*.}"
  patch="$((patch + 1))"
  new_tag="v${major}.${minor}.${patch}"
fi

new_version="${new_tag#v}"

repo_root="$(git rev-parse --show-toplevel)"
ledger="packaging/packages.json"

if ! python3 "${repo_root}/packaging/update_packages_json.py" --version "${new_version}"; then
  echo "pre-push: failed to update ${ledger}, aborting" >&2
  exit 1
fi

git add "${ledger}"
if ! git diff --cached --quiet -- "${ledger}"; then
  echo "pre-push: recording ${new_tag} placeholder in ${ledger}"
  git commit -m "chore: add ${new_tag} placeholder to packages.json"
fi

echo "pre-push: creating and pushing tag ${new_tag}"
git tag "${new_tag}"
SKIP_AUTO_TAG=1 git push "${remote}" HEAD:main "${new_tag}"
